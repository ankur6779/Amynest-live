# Amy Coach stress test — copy to .env.stress.local (gitignored) or export in shell.
# Obtain COACH_STRESS_AUTH_TOKEN from a signed-in AmyNest session (Firebase ID token).

COACH_STRESS_AUTH_TOKEN=
API_URL=http://localhost:5000

# Optional overrides (CLI flags take precedence: --users=50 --batch=10 --profile=high)
# USERS=50
# BATCH_SIZE=10
# COACH_STRESS_PROFILE=medium

# Poll /api/coach/status every 2s until complete (default on; use --no-poll to disable)
# COACH_STRESS_VERBOSE=1
