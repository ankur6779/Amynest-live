<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!--
        POST_NOTIFICATIONS is required on Android 13+ (API 33+).
        The app requests this at runtime in MainActivity.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required for Google Play Billing (in-app purchases / subscriptions). -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <application
        android:name=".AmyNestApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        android:networkSecurityConfig="@xml/network_security_config">

        <!--
            MainActivity: full-screen WebView wrapper for https://amynest.in.
            - Installs window.AmyNestPushNative via WebViewCompat.addWebMessageListener
              so the web app can request/receive native FCM tokens without a Chrome address bar.
            - Handles the android.intent.action.MAIN deep link tap from FCM notifications
              (extras: deepLink = path to open inside the WebView).
            - Also registered as an App Link handler for https://amynest.in so that links
              tapped elsewhere on the device open in this app rather than the browser.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AppCompat.NoActionBar">

            <!-- Launcher icon -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                App Links (Digital Asset Links) — when this passes verification,
                https://amynest.in links opened on the device go directly to this
                activity instead of the browser. Requires assetlinks.json hosted
                at https://amynest.in/.well-known/assetlinks.json (already done).
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="amynest.in" />
            </intent-filter>
        </activity>

        <!--
            FCM default notification icon and colour shown in the system tray
            when FCM itself (not KidScheduleFcmService) displays the notification
            (i.e. notification messages while app is killed — data-only messages
            are always handled by KidScheduleFcmService.onMessageReceived).
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_accent" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="default" />

        <!--
            KidScheduleFcmService: receives FCM messages when the app is in the
            background or killed. channelId "default" matches what the backend
            dispatch service sends in android.notification.channelId.
        -->
        <service
            android:name=".KidScheduleFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
