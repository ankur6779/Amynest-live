<?xml version="1.0" encoding="utf-8"?>
<!--
    Fallback round launcher icon for API 24–25.
    Uses an oval shape to approximate the round clip Android applies.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/brand_indigo" />
        </shape>
    </item>
    <item>
        <drawable android:drawable="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
