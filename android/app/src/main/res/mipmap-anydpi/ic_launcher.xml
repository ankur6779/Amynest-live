<?xml version="1.0" encoding="utf-8"?>
<!--
    Fallback launcher icon for API 24–25 (pre-adaptive-icon).
    layer-list renders as a flat bitmap: brand-indigo square + white "A".
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_indigo" />
        </shape>
    </item>
    <item>
        <drawable android:drawable="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
