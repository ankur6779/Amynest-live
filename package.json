{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "preinstall": "echo ok",
    "postinstall": "node scripts/clean-vite-cache.mjs",
    "prepare": "sh -c 'command -v simple-git-hooks >/dev/null 2>&1 && simple-git-hooks || true'",
    "clean:vite": "node scripts/clean-vite-cache.mjs",
    "clean:web": "pnpm --filter @workspace/kidschedule run clean",
    "reset": "node scripts/clean-vite-cache.mjs --dist && pnpm install",
    "reset:hard": "rm -rf node_modules artifacts/kidschedule/node_modules artifacts/amynest-splash/node_modules && node scripts/clean-vite-cache.mjs --dist && pnpm install",
    "dev": "pnpm run dev:api",
    "dev:api": "pnpm --filter @workspace/api-server dev",
    "dev:web": "pnpm --filter @workspace/kidschedule dev",
    "dev:mobile": "node -e \"console.error('Expo app (artifacts/amynest-mobile) is archived. Use: pnpm dev:web (PWA) + artifacts/amynest-capacitor (iOS).'); process.exit(1)\"",
    "build:api": "pnpm --filter @workspace/api-server build",
    "start:api": "pnpm --filter @workspace/api-server start",
    "build": "pnpm run typecheck && pnpm -r --filter '!@workspace/amynest-mobile' --if-present run build",
    "build:web": "BASE_PATH=/ PORT=3000 pnpm --filter @workspace/kidschedule build",
    "db:migrate": "pnpm --filter @workspace/scripts run migrate-database",
    "stress": "pnpm --filter @workspace/scripts run stress-amy-coach",
    "stability:load": "pnpm --filter @workspace/scripts run stability-load",
    "stability:api-unit": "pnpm --filter @workspace/api-server exec node --import tsx/esm --test src/lib/production-load.test.ts",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"!@workspace/amynest-mobile\" --filter \"./scripts\" --if-present run typecheck",
    "codegen": "pnpm --filter @workspace/api-spec run codegen && pnpm run typecheck:libs"
  },
  "simple-git-hooks": {
    "pre-commit": "sh scripts/check-codegen.sh"
  },
  "private": true,
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.0",
    "@replit/revenuecat-sdk": "4.0.0"
  }
}
