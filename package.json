{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
      "preinstall": "echo ok",
    "prepare": "sh -c 'command -v simple-git-hooks >/dev/null 2>&1 && simple-git-hooks || true'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:web": "BASE_PATH=/ PORT=3000 pnpm --filter @workspace/kidschedule build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "codegen": "pnpm --filter @workspace/api-spec run codegen && pnpm run typecheck:libs"
  },
  "simple-git-hooks": {
    "pre-commit": "sh scripts/check-codegen.sh"
  },
  "private": true,
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.0",
    "@replit/revenuecat-sdk": "4.0.0"
  }
}
