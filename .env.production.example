# Copy to `.env.production` for local production-like builds (never commit secrets).
# On Render, set these in the dashboard for Amynest-backend / Amynest-live-1.

# ─── Profile ─────────────────────────────────────────────────────────────────
AMYNEST_ENV=production
NODE_ENV=production

# ─── API server ──────────────────────────────────────────────────────────────
PORT=10000
API_PUBLIC_URL=https://amynest-backend.onrender.com
LOG_LEVEL=info

GOOGLE_API_KEY=
ELEVENLABS_API_KEY=
DATABASE_URL=postgresql://user:pass@host:5432/amynest_prod

# Redis (BullMQ AI queue) — REQUIRED in production; same URL on API + Worker
REDIS_URL=redis://default:password@redis-host:6379
AI_MAX_CONCURRENT_JOBS=3
AI_JOB_TIMEOUT_MS=10000
# Production BullMQ: 0 = immediate 202; dev in-memory may use 9000
AI_HTTP_WAIT_MS=0
AI_JOB_RESULT_TTL_SEC=600

# ─── Web (Vite) ──────────────────────────────────────────────────────────────
VITE_AMYNEST_ENV=production
VITE_APP_API_ORIGIN=https://amynest-backend.onrender.com

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_VAPID_KEY=

# ─── Expo (EAS / release builds) ─────────────────────────────────────────────
EXPO_PUBLIC_AMYNEST_ENV=production
EXPO_PUBLIC_API_ORIGIN=https://amynest-backend.onrender.com

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
