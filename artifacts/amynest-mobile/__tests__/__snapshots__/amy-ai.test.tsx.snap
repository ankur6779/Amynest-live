exports[`Amy AI tutor screen > renders a QUIZ reply with options and grades the chosen answer > before-pick 1`] = `
<div
  data-colors="["#0b0b1a","#1a1633"]"
>
  <div>
    <button>
      <span
        data-icon="chevron-back"
        style="font-size: 22px; color: rgb(255, 255, 255);"
      />
    </button>
    <div
      data-colors="["#7B3FF2","#FF4ECD"]"
