      <div>
        <span>
          ai.page_title
        </span>
        <div>
          <span>
            ai.tutor_badge
          </span>
        </div>
      </div>
      <span>
        ai.tutor_subtitle
      </span>
    </div>
    <button
      aria-label="ai.clear_chat"
      role="button"
    >
      <span
        data-icon="refresh"
        style="font-size: 14px; color: rgba(255, 255, 255, 0.85);"
      />
      <span>
        ai.clear_chat
      </span>
    </button>
  </div>
  <div
    behavior="padding"
    keyboardverticaloffset="20"
  >
    <div>
      <div>
        <div>
          <button
            aria-label="ai.mode_teach · ai.mode_teach_hint"
            aria-selected="true"
            role="tab"
          >
            <span
              data-icon="school"
              style="font-size: 14px; color: rgb(255, 255, 255);"
