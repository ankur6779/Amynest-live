        </span>
        <div>
          <span>
            ai.tutor_badge
          </span>
        </div>
      </div>
      <span>
        ai.tutor_subtitle
      </span>
    </div>
    <button
      aria-label="ai.clear_chat"
      role="button"
    >
      <span
        data-icon="refresh"
        style="font-size: 14px; color: rgba(255, 255, 255, 0.85);"
      />
      <span>
        ai.clear_chat
      </span>
    </button>
  </div>
  <div
    behavior="padding"
    keyboardverticaloffset="20"
  >
    <div>
      <div>
        <button
          aria-label="ai.mode_teach · ai.mode_teach_hint"
          aria-selected="true"
          role="tab"
        >
          <span
            data-icon="school"
            style="font-size: 14px; color: rgb(255, 255, 255);"
          />
          <span>
            ai.mode_teach
          </span>
        </button>
        <button
          aria-label="ai.mode_practice · ai.mode_practice_hint"
          aria-selected="false"
          role="tab"
        >
          <span
            data-icon="checkbox-multiple-marked-outline"
            style="font-size: 14px; color: rgba(255, 255, 255, 0.75);"
          />
          <span>
            ai.mode_practice
          </span>
        </button>
        <button
          aria-label="ai.mode_quiz · ai.mode_quiz_hint"
          aria-selected="false"
          role="tab"
        >
          <span
            data-icon="lightbulb-on-outline"
            style="font-size: 14px; color: rgba(255, 255, 255, 0.75);"
          />
          <span>
            ai.mode_quiz
          </span>
        </button>
        <button
          aria-label="ai.mode_doubt · ai.mode_doubt_hint"
          aria-selected="false"
          role="tab"
        >
          <span
            data-icon="help-circle-outline"
            style="font-size: 14px; color: rgba(255, 255, 255, 0.75);"
          />
          <span>
            ai.mode_doubt
          </span>
        </button>
      </div>
      <div>
        <button
          aria-selected="true"
          role="tab"
        >
          <span>
            ✨
          </span>
          <span>
            ai.subject_general
          </span>
        </button>
        <button
          aria-selected="false"
          role="tab"
        >
          <span>
            🔢
          </span>
          <span>
            ai.subject_math
          </span>
        </button>
        <button
          aria-selected="false"
          role="tab"
        >
          <span>
            📖
          </span>
          <span>
            ai.subject_english
          </span>
        </button>
        <button
          aria-selected="false"
          role="tab"
        >
          <span>
            🌍
          </span>
          <span>
            ai.subject_gk
          </span>
        </button>
        <button
          aria-selected="false"
          role="tab"
        >
          <span>
            🧩
          </span>
          <span>
            ai.subject_logic
          </span>
        </button>
      </div>
      <input
        placeholder="ai.topic_placeholder"
        placeholdertextcolor="rgba(255,255,255,0.4)"
        value=""
      />
    </div>
    <div>
      <div>
        <div>
          <span>
            Quiz me on addition
          </span>
        </div>
      </div>
      <div>
        <div
          data-colors="["#7B3FF2","#FF4ECD"]"
        >
          <span
            data-icon="brain"
            style="font-size: 14px; color: rgb(255, 255, 255);"
          />
        </div>
        <div>
          <div>
            <div>
              <span>
                Quick one!
              </span>
            </div>
          </div>
          <div>
            <span>
              What is 2 + 3?
            </span>
            <div>
              <button
                aria-disabled="false"
                aria-selected="false"
                role="button"
              >
                <span>
                  4
                </span>
              </button>
              <button
                aria-disabled="false"
                aria-selected="false"
                role="button"
              >
                <span>
                  5
                </span>
              </button>
              <button
                aria-disabled="false"
                aria-selected="false"
                role="button"
              >
                <span>
                  6
                </span>
              </button>
              <button
                aria-disabled="false"
                aria-selected="false"
                role="button"
              >
                <span>
                  7
                </span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div>
      <input
        placeholder="ai.tutor_input_placeholder"
        placeholdertextcolor="rgba(255,255,255,0.4)"
        returnkeytype="send"
        value=""
      />
      <button
        disabled=""
      >
        <div
          data-colors="["#7B3FF2","#FF4ECD"]"
        >
          <span
            data-icon="arrow-up"
            style="font-size: 20px; color: rgb(255, 255, 255);"
          />
        </div>
      </button>
    </div>
    <span>
      ai.disclaimer
    </span>
  </div>
</div>
`;

