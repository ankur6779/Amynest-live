{
  "expo": {
    "name": "AmyNest AI",
    "slug": "amynest-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "amynest",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/amynest-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1530",
      "dark": {
        "image": "./assets/images/amynest-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#1A1530"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.amynest.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AmyNest needs access to your photos so you can set a profile picture for your child.",
        "NSCameraUsageDescription": "AmyNest needs access to your camera so you can take a profile picture for your child.",
        "NSMicrophoneUsageDescription": "AmyNest uses the microphone for voice features in Amy AI Coach (optional).",
        "NSUserTrackingUsageDescription": "We don't track you across other apps. This is only used if you explicitly enable referral attribution.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.amynest.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F8F7FF"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "./plugins/withBlockedPermissions",
      [
        "expo-router",
        {
          "origin": "https://amynest.in"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "AmyNest needs access to your photos so you can set a profile picture for your child.",
          "cameraPermission": "AmyNest needs access to your camera so you can take a profile picture for your child."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/amynest-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1530",
          "dark": {
            "image": "./assets/images/amynest-logo.png",
            "backgroundColor": "#1A1530"
          },
          "android": {
            "image": "./assets/images/adaptive-icon.png",
            "imageWidth": 180,
            "backgroundColor": "#1A1530"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "72266bd6-b9af-48da-8dfd-99e51dd4ebf1"
      }
    }
  }
}