<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">

<!--
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  AmyNest — iOS Info.plist ADDITIONS                                 ║
  ║                                                                      ║
  ║  After running `npx cap add ios` on your Mac, open Xcode and add    ║
  ║  these keys into  ios/App/App/Info.plist  inside the root <dict>.    ║
  ╚══════════════════════════════════════════════════════════════════════╝
-->
<plist version="1.0">
<dict>

  <!-- ── Microphone (Amy Speech Coach read-aloud) ── -->
  <key>NSMicrophoneUsageDescription</key>
  <string>AmyNest uses your microphone for the Speech Coach and pronunciation practice features.</string>

  <!-- ── Camera ── -->
  <key>NSCameraUsageDescription</key>
  <string>AmyNest uses the camera to let you capture your child's milestones and share them in the app.</string>

  <!-- ── Photo Library (read) ── -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>AmyNest accesses your photo library to let you upload your child's photo for their profile.</string>

  <!-- ── Photo Library (add-only) ── -->
  <key>NSPhotoLibraryAddUsageDescription</key>
  <string>AmyNest saves milestone photos to your photo library.</string>

  <!-- ── Push Notifications (handled at runtime — no plist key needed, ──
       ── but the APS environment entitlement IS required in Entitlements) ── -->

  <!-- ── Background Audio (lullaby player in Infant Hub) ── -->
  <key>UIBackgroundModes</key>
  <array>
    <string>audio</string>
    <string>remote-notification</string>
    <string>fetch</string>
  </array>

  <!-- ── Face ID (future biometric lock) ── -->
  <key>NSFaceIDUsageDescription</key>
  <string>AmyNest can use Face ID to securely unlock your parenting data.</string>

  <!-- ── Contacts (optional — for sharing routines) ── -->
  <key>NSContactsUsageDescription</key>
  <string>AmyNest accesses your contacts only when you choose to share a routine via the Share Routine feature.</string>

  <!-- ── App Transport Security: allow Firebase + Clerk domains ── -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoadsInWebContent</key>
    <false/>
    <key>NSExceptionDomains</key>
    <dict>
      <key>amynest.in</key>
      <dict>
        <key>NSIncludesSubdomains</key>
        <true/>
        <key>NSExceptionAllowsInsecureHTTPLoads</key>
        <false/>
        <key>NSExceptionRequiresForwardSecrecy</key>
        <true/>
      </dict>
    </dict>
  </dict>

  <!-- ── Capacitor WKWebView: allow navigating back to app origin ── -->
  <key>WKAppBoundDomains</key>
  <array>
    <string>amynest.in</string>
    <string>clerk.amynest.in</string>
  </array>

  <!-- ── URL Schemes (Google Sign-In redirect) ── -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLSchemes</key>
      <array>
        <!-- Replace with your reversed Google client ID from GoogleService-Info.plist -->
        <!-- e.g. com.googleusercontent.apps.YOUR_CLIENT_ID -->
        <string>com.amynest.app</string>
        <string>capacitor</string>
      </array>
    </dict>
  </array>

  <!-- ── Status bar ── -->
  <key>UIStatusBarStyle</key>
  <string>UIStatusBarStyleLightContent</string>
  <key>UIViewControllerBasedStatusBarAppearance</key>
  <false/>

  <!-- ── Orientation ── -->
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationPortraitUpsideDown</string>
  </array>
  <key>UISupportedInterfaceOrientations~ipad</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationPortraitUpsideDown</string>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>

  <!-- ── Inline media (audio autoplay without user gesture) ── -->
  <key>WKAudiovisualMediaTypes</key>
  <string>none</string>

</dict>
</plist>
