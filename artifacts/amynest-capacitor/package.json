{
  "name": "@workspace/amynest-capacitor",
  "version": "0.0.0",
  "private": true,
  "description": "Capacitor wrapper for AmyNest — builds iOS (Xcode) + Android from the kidschedule PWA",
  "scripts": {
    "build:web": "node scripts/build-web.mjs",
    "sync": "npx cap sync",
    "sync:ios": "npx cap sync ios",
    "sync:android": "npx cap sync android",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android",
    "build:ios": "npm run build:web && npx cap sync ios",
    "build:android": "npm run build:web && npx cap sync android"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^6.0.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@revenuecat/purchases-capacitor": "^9.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
