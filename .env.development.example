# Copy to `.env.development` at the repo root (never commit real secrets).
# Loaded by: api-server (dotenv), Vite web (`--mode development`), Expo (`.env.development`).

# ─── Profile ─────────────────────────────────────────────────────────────────
AMYNEST_ENV=development
NODE_ENV=development

# ─── API server (local) ──────────────────────────────────────────────────────
PORT=5000
API_PUBLIC_URL=http://localhost:5000
LOG_LEVEL=debug

# Backend secrets (use dev/staging keys — not production)
GOOGLE_API_KEY=
ELEVENLABS_API_KEY=
DATABASE_URL=postgresql://user:pass@localhost:5432/amynest_dev

# Optional: weekly recap emails only (not used for signup verification)
# RESEND_API_KEY=
# EMAIL_FROM=AmyNest <hello@amynest.in>

# OpenAI / integrations (if used locally)
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Web (Vite / kidschedule) ─────────────────────────────────────────────────
VITE_AMYNEST_ENV=development
# Point at local API: set VITE_USE_LOCAL_API=1 and leave origin unset, or set explicitly:
VITE_USE_LOCAL_API=1
VITE_APP_API_ORIGIN=http://localhost:5000

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_VAPID_KEY=

# ─── Expo mobile ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_AMYNEST_ENV=development
EXPO_PUBLIC_USE_LOCAL_API=1
EXPO_PUBLIC_API_ORIGIN=http://localhost:5000
# Legacy alias (still supported):
# EXPO_PUBLIC_DOMAIN=localhost:5000

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
