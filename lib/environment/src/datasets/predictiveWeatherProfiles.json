      "emotionalPreparationRecommendations": ["normalise thunder", "prepare a cozy nook", "soft lighting"],
      "caregiverPreparationSuggestions": ["charge devices", "torches accessible", "weighted blanket nearby"]
    },
    "temperature_spike": {
