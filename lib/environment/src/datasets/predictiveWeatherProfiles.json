      "hydrationAdjustment": 1.0,
      "emotionalPreparationRecommendations": ["talk through change of plan", "let child pick indoor backup"],
      "caregiverPreparationSuggestions": ["raincoat ready if commute needed", "prep indoor activity bin"]
    },
    "incoming_storm": {
      "preemptiveScheduleAdjustment": "complete_outdoor_within_60_min_then_indoor_calming",
